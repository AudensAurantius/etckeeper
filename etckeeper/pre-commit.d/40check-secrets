#!/usr/bin/env bash
# Block commits if tracked root-only files aren't encrypted by git-crypt
# and aren't in the allowlist.
set -e

ALLOWLIST="/etc/etckeeper/git-crypt-allowlist"
if ! [[ -e "$ALLOWLIST" ]]; then
    touch "$ALLOWLIST"
elif ! [[ -f "$ALLOWLIST" && -r "$ALLOWLIST" ]]; then
    echo "git-crypt allowlist ${ALLOWLIST} exists but is either not a file or is not readable" >&2
    exit 255
fi

declare -a encrypted secret
mapfile -t encrypted < <(git-crypt status 2>/dev/null | grep "^\s*encrypted:" | awk '{print $2}' | sort)
mapfile -t secret < <(find /etc -type f \! -perm -o=r 2>/dev/null -printf "%P\n")

is_allowed() {
    file="$1"
    while IFS= read -r pattern; do
        case "$pattern" in
            ""|\#*) continue ;;
        esac
        if [[ "$file" == $pattern ]]; then
            return 0
        fi
    done < "$ALLOWLIST"
    return 1
}

declare -i suspect=0
for file in "${secret[@]}"; do
    git ls-files --error-unmatch "$file" >/dev/null 2>&1 || continue
    is_allowed "$file" && continue
    printf '%s\n' "${encrypted[@]}" | grep -qxF "$file" && continue

    echo "ERROR: $file is root-only but NOT encrypted or allowlisted" >&2
    suspect+=1
done

if [[ "$suspect" -gt 0 ]]; then
    echo "Either add to /etc/.gitattributes (encrypt) or /etc/etckeeper/git-crypt-allowlist (allow plaintext)." >&2
    exit 1
fi
